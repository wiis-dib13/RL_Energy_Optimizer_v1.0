{
  "simulation": {
    "appId": "dcns",
    "num_users": 1,
    "areas": 4,
    "cameras_per_area": 4
  },
  "topology": {
    "cloud": {
      "name": "cloud",
      "level": 0,
      "children": [
        "proxy-server"
      ]
    },
    "proxy": {
      "name": "proxy-server",
      "level": 1,
      "children": [
        "fog-0",
        "fog-1",
        "fog-2",
        "fog-3"
      ]
    },
    "fog_devices": [
      {
        "name": "fog-0",
        "level": 2
      },
      {
        "name": "fog-1",
        "level": 2
      },
      {
        "name": "fog-2",
        "level": 2
      },
      {
        "name": "fog-3",
        "level": 2
      }
    ],
    "cameras": [
      "m-0-0",
      "m-0-1",
      "m-0-2",
      "m-0-3",
      "m-1-0",
      "m-1-1",
      "m-1-2",
      "m-1-3",
      "m-2-0",
      "m-2-1",
      "m-2-2",
      "m-2-3",
      "m-3-0",
      "m-3-1",
      "m-3-2",
      "m-3-3"
    ]
  },
  "modules": [
    "motion_detector",
    "object_detector",
    "object_tracker",
    "user_interface"
  ],
  "edges": [
    "CAMERA -> motion_detector",
    "motion_detector -> object_detector",
    "object_detector -> user_interface",
    "object_detector -> object_tracker",
    "object_tracker -> PTZ_CONTROL"
  ],
  "loops": [
    [
      "motion_detector",
      "object_detector",
      "object_tracker"
    ],
    [
      "object_tracker",
      "PTZ_CONTROL"
    ]
  ]
}